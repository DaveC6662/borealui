{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["node", "jest", "jest-axe", "@testing-library/jest-dom"],

    "forceConsistentCasingInFileNames": true,
    "plugins": [{ "name": "next" }]
  },

  "include": [
    "src",
    "scripts",
    "__tests__",
    "jest.setup.ts",
    "jest.config.ts",
    "global.d.ts",
    "./src/types/scss.d.ts",
    "./src/types/types.d.ts",
    "next.config.mjs",
    "stories-core/**/*",
    "stories-next/**/*",
    "webpack.config.cjs",
    "scripts/buildEntryMap.js"
  ],

  "exclude": ["node_modules", "cypress", "dist"]
}
